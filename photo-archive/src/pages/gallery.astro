---
import { existsSync, readFileSync } from 'node:fs';
import { resolve } from 'node:path';
import BaseLayout from '../layouts/BaseLayout.astro';
import PhotoGrid from '../components/PhotoGrid.astro';
import PhotoModal from '../components/PhotoModal.astro';
import navData from '../data/nav.json';
import type { Photo } from '../types';

const photosJsonPath = resolve('src/data/photos.json');
const photos: Photo[] = existsSync(photosJsonPath)
  ? (JSON.parse(readFileSync(photosJsonPath, 'utf-8')).photos as Photo[]) ?? []
  : [];

type SubItem = { label: string; filterKey: string };
type CatData = { slug: string; label: string; subcategories: SubItem[] };

const categoryData: CatData[] = (navData.items as any[])
  .filter(item => item.categorySlug && item.children)
  .map(item => ({
    slug: item.categorySlug as string,
    label: item.label as string,
    subcategories: item.children as SubItem[],
  }));

const existingCategories = [...new Set(photos.map(p => p.category))];
const filteredCategoryData = categoryData.filter(c => existingCategories.includes(c.slug));
---

<BaseLayout title="Gallery - せなーんの写真ライブラリ">
  <div class="w-full max-w-[1600px] mx-auto px-6 py-8">

    <!-- フィルターバー -->
    <div class="flex flex-wrap items-center gap-3 mb-8">

      <!-- カテゴリドロップダウン -->
      <details id="cat-dropdown" class="filter-dd group relative">
        <summary class="dd-trigger">
          <span id="cat-label">すべてのカテゴリ</span>
          <svg class="dd-chevron" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.168l3.71-3.938a.75.75 0 1 1 1.08 1.04l-4.25 4.51a.75.75 0 0 1-1.08 0L5.21 8.27a.75.75 0 0 1 .02-1.06Z" clip-rule="evenodd" />
          </svg>
        </summary>
        <div class="dd-panel">
          <ul class="dd-list">
            <li>
              <button class="dd-item active" data-cat="all">すべてのカテゴリ</button>
            </li>
            {filteredCategoryData.map(cat => (
              <li>
                <button class="dd-item" data-cat={cat.slug}>{cat.label}</button>
              </li>
            ))}
          </ul>
        </div>
      </details>

      <!-- サブカテゴリドロップダウン（カテゴリ選択時のみ表示） -->
      <details id="sub-dropdown" class="filter-dd group relative hidden">
        <summary class="dd-trigger">
          <span id="sub-label">すべて</span>
          <svg class="dd-chevron" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.168l3.71-3.938a.75.75 0 1 1 1.08 1.04l-4.25 4.51a.75.75 0 0 1-1.08 0L5.21 8.27a.75.75 0 0 1 .02-1.06Z" clip-rule="evenodd" />
          </svg>
        </summary>
        <div class="dd-panel">
          <ul id="sub-list" class="dd-list">
            <!-- JS で動的に生成 -->
          </ul>
        </div>
      </details>

    </div>

    <PhotoGrid />
    <PhotoModal />
  </div>

  <!-- トップへ戻るボタン -->
  <button
    id="back-to-top"
    class="fixed bottom-6 right-6 z-30 w-11 h-11 flex items-center justify-center rounded-full bg-gray-900 dark:bg-white text-white dark:text-gray-900 shadow-lg opacity-0 translate-y-2 transition-all duration-200 hover:scale-110 pointer-events-none"
    aria-label="ページトップへ戻る"
  >
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
      <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 15.75 7.5-7.5 7.5 7.5" />
    </svg>
  </button>
</BaseLayout>

<style is:global>
  .filter-dd summary { list-style: none; }
  .filter-dd summary::-webkit-details-marker { display: none; }

  .dd-trigger {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.875rem;
    border-radius: 0.5rem;
    border: 1px solid rgb(229 231 235);
    background-color: white;
    color: rgb(17 24 39);
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: border-color 0.15s, background-color 0.15s;
    white-space: nowrap;
    user-select: none;
    min-width: 9rem;
    justify-content: space-between;
  }

  .dd-trigger:hover {
    border-color: rgb(156 163 175);
    background-color: rgb(249 250 251);
  }

  .filter-dd[open] .dd-trigger {
    border-color: rgb(107 114 128);
    background-color: rgb(249 250 251);
  }

  .dd-chevron {
    width: 1rem;
    height: 1rem;
    color: rgb(113 113 122);
    transition: transform 0.2s;
    flex-shrink: 0;
  }

  .filter-dd[open] .dd-chevron {
    transform: rotate(180deg);
  }

  .dd-panel {
    position: absolute;
    left: 0;
    top: calc(100% + 0.25rem);
    z-index: 50;
    min-width: 11rem;
  }

  .dd-list {
    list-style: none;
    margin: 0;
    padding: 0.375rem;
    border-radius: 0.625rem;
    background-color: rgb(255 255 255 / 0.92);
    box-shadow: 0 4px 16px rgb(0 0 0 / 0.08), 0 1px 3px rgb(0 0 0 / 0.06);
    backdrop-filter: blur(8px);
  }

  .dd-item {
    display: block;
    width: 100%;
    text-align: left;
    padding: 0.5rem 0.75rem;
    border-radius: 0.375rem;
    font-size: 0.875rem;
    color: rgb(17 24 39);
    background: none;
    border: none;
    cursor: pointer;
    transition: background-color 0.1s;
  }

  .dd-item:hover {
    background-color: rgb(243 244 246 / 0.8);
  }

  .dd-item.active {
    background-color: rgb(17 24 39 / 0.07);
    font-weight: 500;
  }

  @media (prefers-color-scheme: dark) {
    .dd-trigger {
      border-color: rgb(55 65 81);
      background-color: rgb(31 41 55);
      color: rgb(243 244 246);
    }

    .dd-trigger:hover,
    .filter-dd[open] .dd-trigger {
      border-color: rgb(75 85 99);
      background-color: rgb(55 65 81);
    }

    .dd-list {
      background-color: rgb(31 41 55 / 0.92);
      box-shadow: 0 4px 16px rgb(0 0 0 / 0.3);
    }

    .dd-item {
      color: rgb(243 244 246);
    }

    .dd-item:hover {
      background-color: rgb(55 65 81 / 0.8);
    }

    .dd-item.active {
      background-color: rgb(243 244 246 / 0.1);
    }
  }
</style>

<script define:vars={{ categoryData: filteredCategoryData, allPhotos: photos }}>
  const PAGE_SIZE = 24;
  const catData = categoryData;

  const catDropdown  = document.getElementById('cat-dropdown');
  const subDropdown  = document.getElementById('sub-dropdown');
  const catLabel     = document.getElementById('cat-label');
  const subLabel     = document.getElementById('sub-label');
  const subList      = document.getElementById('sub-list');
  const grid         = document.getElementById('photo-grid');
  const noResults    = document.getElementById('no-results');
  const sentinel     = document.getElementById('scroll-sentinel');
  const backToTopBtn = document.getElementById('back-to-top');

  let currentCat = 'all';
  let currentSub = 'all';
  let filteredPhotos = [];
  let renderedCount = 0;

  // ---- 写真カード DOM 生成 ----
  function createPhotoCard(photo) {
    const item = document.createElement('div');
    item.className = 'masonry-item';
    item.dataset.filter   = photo.filterKey ?? '';
    item.dataset.category = photo.category ?? '';
    item.dataset.date     = photo.exif?.dateTaken ?? '';

    const btn = document.createElement('button');
    btn.className  = 'group w-full cursor-pointer overflow-hidden rounded-lg focus:outline-none focus-visible:ring-2 focus-visible:ring-gray-400 dark:focus-visible:ring-gray-500';
    btn.dataset.photo = JSON.stringify(photo);
    btn.setAttribute('aria-label', `写真を拡大表示: ${photo.filename}`);

    const img = document.createElement('img');
    img.src       = photo.thumbnail;
    img.alt       = '';
    img.width     = photo.thumbnailWidth;
    img.height    = photo.thumbnailHeight;
    img.loading   = 'lazy';
    img.decoding  = 'async';
    img.className = 'w-full h-auto block transition-transform duration-300 group-hover:scale-105';

    btn.appendChild(img);
    item.appendChild(btn);
    return item;
  }

  // ---- フィルター + ソート ----
  function applyFilter() {
    let result = allPhotos;
    if (currentCat !== 'all') {
      result = result.filter(p => p.category === currentCat);
      if (currentSub !== 'all') result = result.filter(p => p.filterKey === currentSub);
    }
    return result.slice().sort((a, b) => {
      const da = a.exif?.dateTaken ?? '';
      const db = b.exif?.dateTaken ?? '';
      if (!da && !db) return 0;
      if (!da) return 1;
      if (!db) return -1;
      return db.localeCompare(da);
    });
  }

  // ---- 次バッチを DOM に追加 ----
  function appendBatch() {
    if (!grid || renderedCount >= filteredPhotos.length) return [];
    const batch = filteredPhotos.slice(renderedCount, renderedCount + PAGE_SIZE);
    const newItems = batch.map(createPhotoCard);
    newItems.forEach(item => grid.appendChild(item));
    renderedCount += batch.length;
    return newItems;
  }

  // ---- フィルター変更時のリセット ----
  function update() {
    if (!grid) return;

    // 既存カードを削除
    grid.querySelectorAll('.masonry-item').forEach(el => el.remove());
    renderedCount = 0;

    filteredPhotos = applyFilter();
    const hasResults = filteredPhotos.length > 0;

    if (noResults) noResults.classList.toggle('visible', !hasResults);
    grid.style.display = !hasResults ? 'none' : '';

    if (hasResults) {
      appendBatch();
      requestAnimationFrame(() => window.refreshLayout?.());
    }
  }

  // ---- 無限スクロール（IntersectionObserver） ----
  const observer = new IntersectionObserver((entries) => {
    if (!entries[0].isIntersecting) return;
    if (renderedCount >= filteredPhotos.length) return;
    const newItems = appendBatch();
    if (newItems.length > 0) window.appendLayout?.(newItems);
  }, { rootMargin: '300px' });

  if (sentinel) observer.observe(sentinel);

  // ---- サブカテゴリリスト再構築 ----
  function rebuildSubList(catSlug) {
    if (!subList || !subDropdown) return;
    if (catSlug === 'all') { subDropdown.classList.add('hidden'); return; }

    const cat = catData.find(c => c.slug === catSlug);
    if (!cat) { subDropdown.classList.add('hidden'); return; }

    subList.innerHTML = '';
    const items = [{ filterKey: 'all', label: 'すべて' }, ...cat.subcategories];
    items.forEach(sub => {
      const btn = document.createElement('button');
      btn.className = 'dd-item' + (sub.filterKey === 'all' ? ' active' : '');
      btn.dataset.sub = sub.filterKey;
      btn.textContent = sub.label;
      btn.addEventListener('click', () => {
        currentSub = sub.filterKey;
        if (subLabel) subLabel.textContent = sub.label;
        subList.querySelectorAll('.dd-item').forEach(b => b.classList.toggle('active', b.dataset.sub === currentSub));
        subDropdown.removeAttribute('open');
        update();
      });
      const li = document.createElement('li');
      li.appendChild(btn);
      subList.appendChild(li);
    });

    subDropdown.classList.remove('hidden');
    if (subLabel) subLabel.textContent = 'すべて';
  }

  // ---- カテゴリクリック ----
  document.querySelectorAll('#cat-dropdown .dd-item').forEach(btn => {
    btn.addEventListener('click', () => {
      currentCat = btn.dataset.cat;
      currentSub = 'all';
      if (catLabel) catLabel.textContent = btn.textContent;
      document.querySelectorAll('#cat-dropdown .dd-item').forEach(b => b.classList.toggle('active', b.dataset.cat === currentCat));
      catDropdown?.removeAttribute('open');
      rebuildSubList(currentCat);
      update();
    });
  });

  // ---- 外側クリックでドロップダウンを閉じる ----
  document.addEventListener('click', e => {
    if (!catDropdown?.contains(e.target)) catDropdown?.removeAttribute('open');
    if (!subDropdown?.contains(e.target)) subDropdown?.removeAttribute('open');
  });

  // ---- URL パラメータで初期フィルター ----
  const params = new URLSearchParams(location.search);
  const filterParam = params.get('filter');
  if (filterParam && filterParam !== 'all') {
    const matchCat = catData.find(c => c.subcategories.some(s => s.filterKey === filterParam));
    if (matchCat) {
      currentCat = matchCat.slug;
      currentSub = filterParam;
      if (catLabel) catLabel.textContent = matchCat.label;
      document.querySelectorAll('#cat-dropdown .dd-item').forEach(b => b.classList.toggle('active', b.dataset.cat === matchCat.slug));
      rebuildSubList(matchCat.slug);
      const matchSub = matchCat.subcategories.find(s => s.filterKey === filterParam);
      if (matchSub && subLabel) {
        subLabel.textContent = matchSub.label;
        subList?.querySelectorAll('.dd-item').forEach(b => b.classList.toggle('active', b.dataset.sub === filterParam));
      }
    }
  }

  // ---- 初期レンダリング ----
  update();

  // ---- トップへ戻るボタン ----
  window.addEventListener('scroll', () => {
    if (!backToTopBtn) return;
    if (window.scrollY > 300) {
      backToTopBtn.classList.remove('opacity-0', 'translate-y-2', 'pointer-events-none');
      backToTopBtn.classList.add('opacity-100', 'translate-y-0');
    } else {
      backToTopBtn.classList.remove('opacity-100', 'translate-y-0');
      backToTopBtn.classList.add('opacity-0', 'translate-y-2', 'pointer-events-none');
    }
  }, { passive: true });

  backToTopBtn?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
