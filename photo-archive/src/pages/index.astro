---
import { existsSync, readFileSync } from 'node:fs';
import { resolve } from 'node:path';
import BaseLayout from '../layouts/BaseLayout.astro';
import siteData from '../data/site.json';

const featuredJsonPath = resolve('src/data/featured.json');
const featured: { src: string }[] = existsSync(featuredJsonPath)
  ? JSON.parse(readFileSync(featuredJsonPath, 'utf-8')).photos ?? []
  : [];
const { name, bio, sns } = siteData;

const snsIcons: Record<string, string> = {
  github: 'M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.604-3.369-1.34-3.369-1.34-.454-1.157-1.11-1.465-1.11-1.465-.908-.62.069-.608.069-.608 1.003.07 1.532 1.03 1.532 1.03.891 1.529 2.341 1.087 2.91.831.092-.646.349-1.086.635-1.337-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.447-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.547 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.741 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z',
  x: 'M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.26 5.632zm-1.161 17.52h1.833L7.084 4.126H5.117z',
  instagram: 'M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z',
};
---

<BaseLayout title={`${name} - Photography`}>

  <!-- ヒーローセクション -->
  <section class="relative min-h-[85vh] flex items-center justify-center overflow-hidden bg-gray-900">

    {featured.length > 0 ? (
      <div class="absolute inset-0" id="hero-slider">
        {featured.map((photo, i) => (
          <div
            class={`hero-slide absolute inset-0 transition-opacity duration-1000 ${i === 0 ? 'opacity-100' : 'opacity-0'}`}
          >
            <img
              src={photo.src}
              alt=""
              class="w-full h-full object-cover"
              loading={i === 0 ? 'eager' : 'lazy'}
            />
          </div>
        ))}
      </div>
    ) : (
      <div class="absolute inset-0 bg-gradient-to-br from-gray-800 to-gray-950"></div>
    )}

    <!-- ぼかし + 暗いオーバーレイ -->
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>

    <!-- コンテンツ -->
    <div class="relative z-10 flex flex-col items-center text-center text-white px-6 py-16">
      <h1 class="text-5xl sm:text-6xl font-bold tracking-tight mb-4">{name}</h1>

      <p class="text-lg sm:text-xl text-white/75 max-w-sm leading-relaxed mb-8 whitespace-pre-line">
        {bio}
      </p>

      <!-- SNS アイコン（クイックリンク） -->
      <div class="flex items-center gap-5 mb-10">
        {sns.map(link => (
          <a
            href={link.url}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={link.label}
            class="text-white/70 hover:text-white transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6" aria-hidden="true">
              <path d={snsIcons[link.icon] ?? ''} />
            </svg>
          </a>
        ))}
      </div>

      <!-- ギャラリーへのリンク -->
      <a
        href="/gallery/"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-full border border-white/40 text-white/90 text-sm font-medium hover:bg-white/10 hover:border-white/70 transition-all"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />
        </svg>
        ギャラリーを見る
      </a>
    </div>

    <!-- 下矢印（クリックで About セクションへスクロール） -->
    <a
      href="#about"
      class="absolute bottom-8 left-1/2 -translate-x-1/2 text-white/50 hover:text-white/90 transition-colors animate-bounce"
      aria-label="詳細を見る"
    >
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
        <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
      </svg>
    </a>
  </section>

  <!-- About セクション -->
  <section id="about" class="py-20 px-6">
    <div class="max-w-xl mx-auto">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-3">About</h2>
      <p class="text-gray-500 dark:text-gray-400 leading-relaxed mb-10">
        {bio}
      </p>

      <!-- SNS リンク一覧（説明付き） -->
      <h3 class="text-xs font-semibold uppercase tracking-widest text-gray-400 dark:text-gray-500 mb-4">Links</h3>
      <ul class="space-y-3">
        {sns.map(link => (
          <li>
            <a
              href={link.url}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-4 p-4 rounded-xl border border-gray-200 dark:border-gray-800 hover:border-gray-400 dark:hover:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-all group"
            >
              <!-- アイコン -->
              <span class="shrink-0 w-9 h-9 flex items-center justify-center rounded-lg bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300 group-hover:bg-gray-200 dark:group-hover:bg-gray-700 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5" aria-hidden="true">
                  <path d={snsIcons[link.icon] ?? ''} />
                </svg>
              </span>

              <!-- テキスト -->
              <div class="flex-1 min-w-0">
                <p class="text-sm font-semibold text-gray-900 dark:text-white">{link.label}</p>
                {link.description && (
                  <p class="text-sm text-gray-500 dark:text-gray-400 truncate">{link.description}</p>
                )}
              </div>

              <!-- 外部リンクアイコン -->
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 shrink-0 text-gray-300 dark:text-gray-600 group-hover:text-gray-500 dark:group-hover:text-gray-400 transition-colors">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
              </svg>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

</BaseLayout>

<script>
  // スライダー（5秒間隔）
  const slides = document.querySelectorAll<HTMLElement>('.hero-slide');
  if (slides.length > 1) {
    let current = 0;
    setInterval(() => {
      slides[current].classList.remove('opacity-100');
      slides[current].classList.add('opacity-0');
      current = (current + 1) % slides.length;
      slides[current].classList.remove('opacity-0');
      slides[current].classList.add('opacity-100');
    }, 5000);
  }

  // スムーズスクロール（#about へのアンカー）
  document.querySelector('a[href="#about"]')?.addEventListener('click', e => {
    e.preventDefault();
    document.getElementById('about')?.scrollIntoView({ behavior: 'smooth' });
  });
</script>
