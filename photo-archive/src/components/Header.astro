---
import Navigation from "./Navigation.astro";
---

<header class="bg-white/90 dark:bg-gray-900/90 shadow-lg shadow-black/5">
    <div class="mx-auto grid max-w-[1400px] grid-cols-[1fr_auto_1fr] items-center px-8 py-3">
        <div class="justify-self-start">
        <a href="/" class="inline-flex items-center text-[15px] font-medium text-gray-900 dark:text-white">
             <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
            </svg>
            <span>Home</span>
        </a>
        </div>

        <div class="justify-self-center">
            <Navigation />
        </div>

        <div class="justify-self-end">
            <!-- 右側は今は空でOK。あとでAboutやSNSを置ける -->
        </div>
    </div>
</header>