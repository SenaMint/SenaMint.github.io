---
import Navigation from "./Navigation.astro";
import navData from "../data/nav.json";

type NavChild = { label: string; filterKey: string };
type NavItem =
  | { label: string; href: string; categorySlug?: never; children?: never }
  | { label: string; href?: never; categorySlug: string; children: NavChild[] };

const items = navData.items as NavItem[];
---

<header class="bg-white/90 dark:bg-gray-900/90 backdrop-blur shadow-sm shadow-black/5 sticky top-0 z-40">

  <!-- モバイル用ヘッダー（ハンバーガー左・ロゴ右） -->
  <div class="flex items-center px-6 py-3 md:hidden">
    <button
      id="hamburger-btn"
      aria-label="メニューを開く"
      aria-expanded="false"
      class="p-2 -ml-2 rounded-md text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
    >
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
    </button>

    <a href="/" class="ml-auto inline-flex items-center gap-2 text-[15px] font-medium text-gray-900 dark:text-white">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5">
        <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
      </svg>
      <span>Home</span>
    </a>
  </div>

  <!-- デスクトップ用ヘッダー -->
  <div class="hidden md:grid grid-cols-[1fr_auto_1fr] items-center px-8 py-3 max-w-[1400px] mx-auto">
    <div class="justify-self-start">
      <a href="/" class="inline-flex items-center gap-2 text-[15px] font-medium text-gray-900 dark:text-white hover:text-black dark:hover:text-gray-200 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
        </svg>
        <span>Home</span>
      </a>
    </div>

    <div class="justify-self-center">
      <Navigation />
    </div>

    <div class="justify-self-end"></div>
  </div>

</header>

<!-- モバイルメニュー（全画面オーバーレイ） -->
<div
  id="mobile-menu"
  class="hidden fixed inset-0 z-50 bg-white dark:bg-gray-900 flex flex-col"
  aria-modal="true"
  role="dialog"
>
  <div class="flex items-center justify-between px-6 py-4 border-b border-gray-200 dark:border-gray-800">
    <span class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">メニュー</span>
    <button
      id="mobile-close-btn"
      aria-label="メニューを閉じる"
      class="p-2 rounded-md text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
    >
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <nav class="flex-1 overflow-y-auto px-6 py-8">
    <ul class="space-y-8">
      <li>
        <a href="/" class="text-lg font-medium text-gray-900 dark:text-white">Home</a>
      </li>
      {items.map(item => (
        <li>
          {item.href ? (
            /* 直リンク */
            <a href={item.href} class="text-lg font-medium text-gray-900 dark:text-white">
              {item.label}
            </a>
          ) : (
            /* ドロップダウン（展開リスト） */
            <>
              <p class="text-xs font-semibold uppercase tracking-widest text-gray-400 dark:text-gray-500 mb-3">
                {item.label}
              </p>
              <ul class="space-y-3 pl-1">
                {item.children?.map(child => (
                  <li>
                    <a
                      href={`/gallery/?filter=${child.filterKey}`}
                      class="text-base text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white transition-colors"
                    >
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            </>
          )}
        </li>
      ))}
    </ul>
  </nav>
</div>

<script>
  const hamburgerBtn = document.getElementById('hamburger-btn') as HTMLButtonElement;
  const closeBtn = document.getElementById('mobile-close-btn') as HTMLButtonElement;
  const mobileMenu = document.getElementById('mobile-menu') as HTMLDivElement;

  function openMenu() {
    mobileMenu.classList.remove('hidden');
    hamburgerBtn.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    mobileMenu.classList.add('hidden');
    hamburgerBtn.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  hamburgerBtn.addEventListener('click', openMenu);
  closeBtn.addEventListener('click', closeMenu);
  mobileMenu.querySelectorAll('a').forEach(link => link.addEventListener('click', closeMenu));
</script>
