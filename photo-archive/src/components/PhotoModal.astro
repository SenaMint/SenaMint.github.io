---
// PhotoModal.astro
// dialog 要素を使ったモーダル。
// PhotoCard の data-photo 属性をクリックで取得し、表示する。
---

<dialog
  id="photo-modal"
  class="max-w-[95vw] max-h-[95vh] w-full bg-white dark:bg-gray-900 rounded-xl shadow-2xl p-0 overflow-hidden"
>
  <div class="flex flex-col md:flex-row h-full max-h-[95vh]">
    <!-- 画像エリア -->
    <div class="flex-1 flex items-center justify-center bg-black min-h-0">
      <img
        id="modal-img"
        src=""
        alt=""
        class="max-w-full max-h-[60vh] md:max-h-[95vh] object-contain"
      />
    </div>

    <!-- EXIF パネル -->
    <div class="md:w-64 shrink-0 flex flex-col bg-white dark:bg-gray-900">
      <div class="flex justify-end p-3">
        <button
          id="modal-close"
          class="text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 text-2xl leading-none w-8 h-8 flex items-center justify-center rounded-full hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
          aria-label="閉じる"
        >
          ✕
        </button>
      </div>

      <div id="modal-exif" class="px-4 pb-4 overflow-y-auto text-sm space-y-3 text-gray-700 dark:text-gray-300">
        <!-- JS で動的に挿入 -->
      </div>
    </div>
  </div>
</dialog>

<style>
  dialog {
    border: none;
    padding: 0;
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    margin: 0;
  }

  dialog::backdrop {
    background: rgba(0, 0, 0, 0.75);
    backdrop-filter: blur(4px);
  }

  /*
   * iOS では全ブラウザが WebKit を利用するため（Safari/Chrome 含む）、
   * dialog::backdrop の blur 合成でモーダル内画像まで暗く見える不具合が起こりうる。
   * iOS のみ backdrop-filter を無効化して回避する。
   */
  dialog.ios-modal-fix::backdrop {
    -webkit-backdrop-filter: none;
    backdrop-filter: none;
    background: rgba(0, 0, 0, 0.6);
  }

  dialog.ios-modal-fix #modal-img {
    opacity: 1;
    filter: none;
    -webkit-filter: none;
  }

</style>

<script>
  import type { Photo } from '../types';

  const modal = document.getElementById('photo-modal') as HTMLDialogElement;
  const img = document.getElementById('modal-img') as HTMLImageElement;
  const exifPanel = document.getElementById('modal-exif') as HTMLDivElement;
  const closeBtn = document.getElementById('modal-close') as HTMLButtonElement;
  const ua = navigator.userAgent;
  const isIOS = /iPhone|iPad|iPod/.test(ua) ||
    (ua.includes('Macintosh') && navigator.maxTouchPoints > 1);

  if (isIOS) {
    modal.classList.add('ios-modal-fix');
  }

  // 閉じる
  closeBtn.addEventListener('click', () => modal.close());
  modal.addEventListener('click', e => {
    if (e.target === modal) modal.close();
  });

  // 写真カードのクリックを受け取る（イベント委譲）
  document.addEventListener('click', e => {
    const card = (e.target as Element).closest<HTMLButtonElement>('[data-photo]');
    if (!card) return;

    const photo: Photo = JSON.parse(card.dataset.photo!);
    openModal(photo);
  });

  function openModal(photo: Photo) {
    // iOS WebKit の GPU テクスチャ上限は約 4096px。
    // 縦長の display 画像（例: 3840×5760）は高さが上限を超えるため表示されない。
    // 上限を超える場合は thumbnail を使用する（display 画像を 1920px 以下で再生成すれば解消）。
    const maxDim = Math.max(photo.displayWidth, photo.displayHeight);
    img.src = isIOS && maxDim > 4096 ? photo.thumbnail : photo.display;
    img.alt = photo.filename;
    renderExif(exifPanel, photo.exif);
    modal.showModal();
  }

  function renderExif(container: HTMLDivElement, exif: Photo['exif']) {
    container.replaceChildren();
    const rows: { label: string; value: string }[] = [];

    if (exif.dateTaken) {
      const d = new Date(exif.dateTaken);
      rows.push({
        label: '撮影日時',
        value: d.toLocaleString('ja-JP', {
          year: 'numeric', month: '2-digit', day: '2-digit',
          hour: '2-digit', minute: '2-digit',
        }),
      });
    }

    if (exif.camera)       rows.push({ label: 'カメラ', value: exif.camera });
    if (exif.lens)         rows.push({ label: 'レンズ', value: exif.lens });
    if (exif.focalLength)  rows.push({ label: '焦点距離', value: `${exif.focalLength}mm` });
    if (exif.aperture)     rows.push({ label: '絞り値', value: `f/${exif.aperture}` });
    if (exif.shutterSpeed) rows.push({ label: 'SS', value: exif.shutterSpeed });
    if (exif.iso)          rows.push({ label: 'ISO', value: String(exif.iso) });

    if (rows.length === 0) {
      const empty = document.createElement('p');
      empty.className = 'text-gray-400 dark:text-gray-500';
      empty.textContent = 'EXIF 情報なし';
      container.appendChild(empty);
      return;
    }

    const fragment = document.createDocumentFragment();
    rows.forEach(({ label, value }) => {
      const wrapper = document.createElement('div');

      const dt = document.createElement('dt');
      dt.className = 'text-xs text-gray-400 dark:text-gray-500 mb-0.5';
      dt.textContent = label;

      const dd = document.createElement('dd');
      dd.className = 'font-medium';
      dd.textContent = value;

      wrapper.append(dt, dd);
      fragment.appendChild(wrapper);
    });

    container.appendChild(fragment);
  }
</script>
